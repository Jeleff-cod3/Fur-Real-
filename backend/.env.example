DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Preferred production/dev-service database:
# DATABASE_URL=postgres://cavegame:cavegame@localhost:5432/cavegame
#
# Or use POSTGRES_* variables:
# POSTGRES_DB=cavegame
# POSTGRES_USER=cavegame
# POSTGRES_PASSWORD=cavegame
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

REDIS_URL=redis://127.0.0.1:6379/0
# Optional JSON object merged into Redis host config.
# Example: {"socket_connect_timeout":5,"socket_timeout":5}
CHANNEL_REDIS_HOST_OPTIONS_JSON=
# Legacy compatibility alias for old deployments that used connection_kwargs.
CHANNEL_REDIS_CONNECTION_KWARGS_JSON=
# Optional JSON object merged into CHANNEL_LAYERS["default"]["CONFIG"].
# If it includes "connection_kwargs", it is normalized to host options.
CHANNEL_LAYER_CONFIG_JSON=
# Set true for local tests without Redis:
USE_IN_MEMORY_CHANNEL_LAYER=false
